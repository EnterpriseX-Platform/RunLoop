# RunLoop environment template. Copy to `.env` and fill in real values.
# DO NOT commit your filled-in `.env` — it's already in .gitignore.

# ── Database ────────────────────────────────────────────────────────────
# Use TLS in production: append ?sslmode=require (or verify-full).
DATABASE_URL=postgres://runloop:CHANGE_ME@localhost:5481/runloop?sslmode=disable

# ── Authentication ──────────────────────────────────────────────────────
# JWT_SECRET — REQUIRED in production. Must be ≥ 32 random chars and not
# a known default. Generate one:  openssl rand -hex 48
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET_AT_LEAST_32_CHARS

# Secret-vault key for AES-256-GCM at rest. Must be 64 hex chars (256 bits).
# Generate:  openssl rand -hex 32
# Both web and engine must share the same value.
SECRET_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARACTERS

# Auth bypass for local dev only. Server-only env (no NEXT_PUBLIC prefix).
# Setting this with NODE_ENV=production will hard-fail at startup.
SKIP_AUTH=false

# ── Seed user (npm run db:seed) ─────────────────────────────────────────
# If unset, the seed script generates a random password and prints it once.
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=

# ── Service URLs ────────────────────────────────────────────────────────
ENGINE_URL=http://localhost:8092

# ── Engine (Go) ─────────────────────────────────────────────────────────
EXECUTOR_PORT=8092
BASE_PATH=/rl

# Worker pool sizing
WORKER_COUNT=10
WORKER_QUEUE_SIZE=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# ── Optional integrations (set when you need them) ──────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# Node runtime (production):  set NODE_ENV=production
NODE_ENV=development
