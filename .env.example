# Database
DATABASE_URL=postgres://runloop:runloop_secret@localhost:5481/runloop?sslmode=disable

# JWT — REQUIRED: must be >= 32 chars and not a known default; engine will fatal on startup otherwise
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET_AT_LEAST_32_CHARS

# RunLoop Web (Next.js)
NEXT_PUBLIC_SKIP_AUTH=true
ENGINE_URL=http://localhost:8081

# RunLoop Engine (Go)
EXECUTOR_PORT=8092
BASE_PATH=/runloop-engine

# Worker Pool
WORKER_COUNT=10
WORKER_QUEUE_SIZE=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=console
